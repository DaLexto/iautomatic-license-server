generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model License {
  id               Int       @id @default(autoincrement())
  licenseKey       String    @unique
  status           String
  durationDays     Int
  firstActivatedAt DateTime?
  expiresAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}